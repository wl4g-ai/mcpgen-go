{
  "$defs": {
    "CallSpec": {
      "additionalProperties": false,
      "properties": {
        "args": {
          "additionalProperties": true,
          "type": "object"
        },
        "parse": {
          "enum": [
            "json"
          ],
          "type": "string"
        },
        "tool": {
          "type": "string"
        }
      },
      "required": [
        "tool",
        "args"
      ],
      "type": "object"
    },
    "EmitSpec": {
      "additionalProperties": false,
      "properties": {
        "expr": {
          "type": "string"
        },
        "from": {
          "type": "string"
        },
        "vars": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "type": "object"
    },
    "ForeachSpec": {
      "additionalProperties": false,
      "properties": {
        "as": {
          "type": "string"
        },
        "concurrency": {},
        "in": {
          "type": "string"
        },
        "pipeline": {
          "items": {
            "$ref": "#/$defs/Step"
          },
          "minItems": 1,
          "type": "array"
        },
        "preserveOrder": {
          "type": "boolean"
        }
      },
      "required": [
        "in",
        "as",
        "pipeline"
      ],
      "type": "object"
    },
    "JQSpec": {
      "additionalProperties": false,
      "properties": {
        "expr": {
          "type": "string"
        },
        "from": {
          "type": "string"
        },
        "vars": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "required": [
        "expr"
      ],
      "type": "object"
    },
    "RequireConfig": {
      "additionalProperties": false,
      "properties": {
        "message": {
          "type": "string"
        },
        "nonEmpty": {
          "type": "boolean"
        }
      },
      "required": [
        "nonEmpty"
      ],
      "type": "object"
    },
    "ReturnSpec": {
      "additionalProperties": false,
      "properties": {
        "expr": {
          "type": "string"
        },
        "from": {
          "type": "string"
        },
        "vars": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "type": "object"
    },
    "Step": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "call"
              }
            }
          },
          "then": {
            "properties": {
              "spec": {
                "$ref": "#/$defs/CallSpec"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "jq"
              }
            }
          },
          "then": {
            "properties": {
              "spec": {
                "$ref": "#/$defs/JQSpec"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "foreach"
              }
            }
          },
          "then": {
            "properties": {
              "spec": {
                "$ref": "#/$defs/ForeachSpec"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "return"
              }
            }
          },
          "then": {
            "properties": {
              "spec": {
                "$ref": "#/$defs/ReturnSpec"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "emit"
              }
            }
          },
          "then": {
            "properties": {
              "spec": {
                "$ref": "#/$defs/EmitSpec"
              }
            }
          }
        }
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "call",
            "jq",
            "foreach",
            "return",
            "emit"
          ],
          "type": "string"
        },
        "require": {
          "$ref": "#/$defs/RequireConfig"
        },
        "spec": {}
      },
      "required": [
        "id",
        "kind",
        "spec"
      ],
      "type": "object"
    },
    "VirtualTool": {
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "additionalProperties": true,
          "type": "object"
        },
        "description": {
          "type": "string"
        },
        "inputSchema": {
          "additionalProperties": true,
          "type": "object"
        },
        "name": {
          "type": "string"
        },
        "pipeline": {
          "items": {
            "$ref": "#/$defs/Step"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": [
        "name",
        "pipeline"
      ],
      "type": "object"
    }
  },
  "$id": "https://mcpgen/schemas/virtual-tool-config",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Schema for mcpgen virtual tool pipeline configuration ($HOME/.\u003cbinary\u003e/config.yaml). Generated from Go structs: config/config.go, pipeline/types.go, pipeline/validator.go",
  "properties": {
    "virtualTools": {
      "items": {
        "$ref": "#/$defs/VirtualTool"
      },
      "minItems": 1,
      "type": "array"
    }
  },
  "required": [
    "virtualTools"
  ],
  "title": "VirtualToolConfig",
  "type": "object"
}